        "query": "/* Primero guardamos la opinión del producto si el pedido ya fue entregado */\nUPDATE pedidos \nSET opinion_producto = '{{ $node[\"Webhook\"].json.body.entry[0].changes[0].value.messages[0].text.body }}'\nWHERE numero_whatsapp LIKE '%' || RIGHT('{{ $node[\"Webhook\"].json.body.entry[0].changes[0].value.messages[0].from.toString() }}', 10)\n  AND estado_pedido = 'Entregado'\n  AND opinion_tiempo IS NOT NULL \n  AND opinion_producto IS NULL;\n\n/* Luego buscamos el nombre para que la IA siga sabiendo con quién habla */\nSELECT nombres_apellidos FROM usuarios \nWHERE numero_whatsapp LIKE '%' || RIGHT('{{ $node[\"Webhook\"].json.body.entry[0].changes[0].value.messages[0].from.toString() }}', 10);",
